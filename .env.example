# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite in project root. Change to PostgreSQL for production:
# DATABASE_URL=postgresql://user:password@localhost:5432/betterproduct
DATABASE_URL=sqlite:///./betterproduct.db

# ── Scraping ──────────────────────────────────────────────────────────────────
HEADLESS_BROWSER=true
SCRAPER_TIMEOUT=30000
MAX_SEARCH_RESULTS=5

# ── Cache TTL (seconds) ───────────────────────────────────────────────────────
PRODUCT_CACHE_TTL=86400     # 24 hours
SEARCH_CACHE_TTL=3600       # 1 hour

# ── Optional: eBay Browse API (improves eBay search quality) ─────────────────
# Get free key at https://developer.ebay.com/
# EBAY_APP_ID=your_app_id_here

# ── Optional: ScraperAPI (bypass anti-bot measures) ──────────────────────────
# Get free tier at https://www.scraperapi.com/
# SCRAPERAPI_KEY=your_key_here

# ── Optional: Local LLM via Ollama (richer explanations) ─────────────────────
# Install Ollama: https://ollama.ai  then: ollama pull llama3
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Embeddings model ──────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Similarity thresholds (0.0 – 1.0) ────────────────────────────────────────
SIMILARITY_THRESHOLD_EXACT=0.92
SIMILARITY_THRESHOLD_HIGH=0.80
SIMILARITY_THRESHOLD_MEDIUM=0.60
